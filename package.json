{
  "name": "@badhiya/mobile-app",
  "version": "0.1.0",
  "private": true,
  "description": "BADHIYA — AI-powered business OS mobile app for Indian MSMEs",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "maestro test .maestro/",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "eas:build:dev": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform android",
    "eas:build:production": "eas build --profile production --platform all",
    "eas:update:staging": "eas update --channel staging",
    "eas:update:production": "eas update --channel production",
    "fix": "npx expo install --fix"
  },
  "dependencies": {
    "expo": "~55.0.15",
    "expo-router": "~55.0.12",
    "expo-constants": "~55.0.14",
    "expo-linking": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-splash-screen": "~55.0.18",
    "expo-font": "~55.0.6",
    "expo-localization": "~55.0.13",
    "expo-audio": "~55.0.13",
    "expo-speech": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-secure-store": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-background-task": "~55.0.16",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-file-system": "~55.0.16",
    "expo-linear-gradient": "~55.0.13",
    "expo-network": "~55.0.13",
    "nanoid": "^5.0.0",
    "@expo-google-fonts/hind": "^0.4.0",
    "@expo-google-fonts/anek-devanagari": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "lucide-react-native": "^0.460.0",
    "react": "19.2.0",
    "react-native": "0.85.1",
    "react-native-reanimated": "~4.3.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "~15.15.4",
    "react-native-mmkv": "^3.2.0",
    "@shopify/react-native-skia": "^2.0.0",
    "victory-native": "^41.0.0",
    "lottie-react-native": "^7.0.0",
    "@legendapp/state": "3.0.0-beta.46",
    "@tanstack/react-query": "^5.96.0",
    "drizzle-orm": "^0.36.0",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.23.0",
    "i18next": "^23.16.0",
    "react-i18next": "^15.0.0",
    "axios": "^1.7.0",
    "date-fns": "^4.1.0",
    "@sentry/react-native": "^5.30.0",
    "posthog-react-native": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "typescript": "~5.6.0",
    "drizzle-kit": "^0.27.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "@testing-library/react-native": "^12.8.0",
    "@testing-library/jest-native": "^5.4.0",
    "eslint": "~8.57.1",
    "eslint-config-expo": "~8.0.0",
    "prettier": "^3.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.(ts|tsx)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "babel-jest",
        {
          "presets": [
            ["@babel/preset-typescript", { "allowDeclareFields": true }]
          ],
          "plugins": [
            "@babel/plugin-transform-modules-commonjs"
          ],
          "babelrc": false,
          "configFile": false
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@theme$": "<rootDir>/src/theme/index.ts",
      "^@theme/(.*)$": "<rootDir>/src/theme/$1"
    }
  }
}
