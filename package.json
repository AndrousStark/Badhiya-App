{
  "name": "@badhiya/mobile-app",
  "version": "0.1.0",
  "private": true,
  "description": "BADHIYA — AI-powered business OS mobile app for Indian MSMEs",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "maestro test .maestro/",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "eas:build:dev": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform android",
    "eas:build:production": "eas build --profile production --platform all",
    "eas:update:staging": "eas update --channel staging",
    "eas:update:production": "eas update --channel production",
    "fix": "npx expo install --fix"
  },
  "dependencies": {
    "expo": "~55.0.9",
    "expo-router": "~6.0.0",
    "expo-constants": "~18.0.0",
    "expo-linking": "~8.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-font": "~14.0.0",
    "expo-localization": "~17.0.0",
    "expo-audio": "~0.5.0",
    "expo-speech": "~14.0.0",
    "expo-sqlite": "~16.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-local-authentication": "~17.0.0",
    "expo-notifications": "~0.32.0",
    "expo-background-task": "~1.0.0",
    "expo-haptics": "~15.0.0",
    "expo-image": "~2.0.0",
    "expo-image-manipulator": "~13.0.0",
    "expo-document-picker": "~14.0.0",
    "expo-camera": "~16.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-file-system": "~20.0.0",
    "expo-linear-gradient": "~15.0.0",
    "expo-network": "~8.0.0",
    "nanoid": "^5.0.0",
    "@expo-google-fonts/hind": "^0.4.0",
    "@expo-google-fonts/anek-devanagari": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "lucide-react-native": "^0.460.0",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-safe-area-context": "~5.0.0",
    "react-native-screens": "~4.0.0",
    "react-native-svg": "~15.0.0",
    "react-native-mmkv": "^3.2.0",
    "@shopify/react-native-skia": "^2.0.0",
    "victory-native": "^41.0.0",
    "lottie-react-native": "^7.0.0",
    "@legendapp/state": "3.0.0-beta.46",
    "@tanstack/react-query": "^5.96.0",
    "drizzle-orm": "^0.36.0",
    "react-hook-form": "^7.54.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.23.0",
    "i18next": "^23.16.0",
    "react-i18next": "^15.0.0",
    "axios": "^1.7.0",
    "date-fns": "^4.1.0",
    "@sentry/react-native": "^5.30.0",
    "posthog-react-native": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~5.6.0",
    "drizzle-kit": "^0.27.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "@testing-library/react-native": "^12.8.0",
    "@testing-library/jest-native": "^5.4.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~8.0.0",
    "prettier": "^3.3.0"
  }
}
