# =========================================
# BADHIYA MOBILE — Environment Variables
# =========================================
# Copy this file to .env and fill in values.
# Only EXPO_PUBLIC_* variables are exposed to the app.
# Secrets stay server-side in the NestJS backend.

# Backend API — local Android emulator uses 10.0.2.2 to reach host
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api/v1

# PostHog analytics (client key is safe to expose)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (auth token only for local source-map uploads)
SENTRY_AUTH_TOKEN=

# DO NOT put Bhashini / NBFC / OpenRouter keys here — mobile talks
# only to our NestJS backend which holds those secrets.
